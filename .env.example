# ========================
# Database Configuration
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=password
DB_NAME=speech_db
DB_SSLMODE=disable

# ========================
# Redis Configuration
# ========================
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# ========================
# Message Queue Configuration
# ========================
MQ_URL=amqp://guest:guest@localhost:5672/
MQ_PREFETCH_COUNT=10

# ========================
# Storage Configuration
# ========================
AWS_REGION=us-east-1
AWS_S3_BUCKET=speech-to-text-service
AWS_ACCESS_KEY=minioadmin
AWS_SECRET_KEY=minioadmin
AWS_ENDPOINT=http://localhost:9000
AWS_PUBLIC_ENDPOINT=http://localhost:9000
EXPIRATION_IN_MINUTES=15

# ========================
# AI Service Configuration
# ========================
WHISPER_API_URL=http://whisper-asr:9010/asr?task=transcribe&output=json
OLLAMA_API_URL=http://ollama_api:11434/api/chat
OLLAMA_MODEL=qwen2.5:1.5b

# ========================
# Environment Configuration (mock/local/production)
# ========================
ENV=local

# ========================
# STT Service Configuration
# ========================
OPENAI_API_KEY=your-openai-api-key

# ========================
# API Server Configuration
# ========================
API_PORT=8080

# ========================
# OpenTelemetry Configuration
# ========================
OTEL_SERVICE_NAME=api-server
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317